# MovieBlast API Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - it's already in .gitignore

# MovieBlast API Base URL
API_BASE_URL=https://your-api-base-url.com/api

# MovieBlast API Authorization Code (Bearer token)
API_AUTH_CODE=your_api_auth_code_here

# TMDB Image Base URL (default is public)
IMAGE_BASE_URL=https://image.tmdb.org/t/p/w500/

# Backend API URL
BACKEND_URL=https://your-backend-url.com

# MovieBlast API Key
MOVIE_API_KEY=your_movie_api_key_here

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# APK Playback Signing Secret (from decompiled MovieBlast APK)
# This is the HMAC secret used for generating verify= tokens
APK_VERIFY_SECRET=your_apk_verify_secret_here

# Default Playback Headers (mimic APK's ExoPlayer behavior)
# These are sent with every media request
PLAYBACK_DEFAULT_REFERER=your_referer_here
PLAYBACK_DEFAULT_USER_AGENT=your_user_agent_here
PLAYBACK_X_REQUEST_X=your_x_request_x_here
PLAYBACK_ACCEPT_ENCODING=your_accept_encoding_here
